# nestrs — development-only overrides (NESTRS_ENV=development, the default).
# Committed; layered on top of `.env`, below `.env.local` and the real environment.

# Verbose, human-readable logs while developing.
NESTRS_OPENTELEMETRY__LOG_LEVEL=debug
NESTRS_OPENTELEMETRY__LOG_FORMAT=text

# GraphQL dev tooling — off by default (production-safe), turned on here for
# development: serve the playground and (re)write the committed SDL on boot. The
# SDL path targets the api app's committed file (cargo runs from the workspace root).
NESTRS_GRAPHQL__PLAYGROUND=true
NESTRS_GRAPHQL__EMIT_SDL=true
NESTRS_GRAPHQL__SCHEMA_PATH=apps/publish-api/schema.graphql
