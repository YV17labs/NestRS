# nestrs — template for `.env.local` (git-ignored). The devcontainer copies this
# to `.env.local` on create; copy it by hand on bare metal:
#
#   cp .env.example .env.local
#
# It holds the SECRET-shaped settings kept out of the committed `.env` cascade:
# the JWT signing key and the OAuth client secret. The values below are NON-SECRET
# demo values for local development — replace them with real ones (here or, in
# production, via the real environment) for a live setup. Real secrets must never
# be committed; `.env.local` is git-ignored for exactly this reason.

# JWT signing key (EdDSA private key). The `auth` issuer signs tokens with it; the
# `api` resource server never needs it (it verifies with the public key in `.env`).
NESTRS_AUTHN__PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIEYTRN4vmCuIfaUslO5G9pKyxkDJn3q3t9WDHo2FCfw3\n-----END PRIVATE KEY-----\n"

# OAuth2 client secret for the `auth` issuer's provider.
NESTRS_AUTHN__CLIENT_SECRET=demo-client-secret

# Registered clients of the `auth` issuer's `/token` endpoint (the
# `client_credentials` grant). A JSON array; each client authenticates with HTTP
# Basic (`client_id:client_secret`) and may mint tokens only for its `org_id` and
# within its `scopes`. The secrets make this secret-shaped, so it lives here.
NESTRS_ISSUER__CLIENTS=[{"client_id":"demo-service","client_secret":"demo-service-secret","org_id":"018f0000-0000-7000-8000-000000000000","scopes":["admin","user"]}]
