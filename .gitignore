# Rust build artifacts
/target
**/*.rs.bk

# Coverage output (cargo-llvm-cov)
*.profraw
*.profdata
/coverage
lcov.info

# Local environment / secrets. The committed cascade (`.env`, `.env.<env>`) holds
# only non-secret overrides; per-machine secrets go in `.local` files, never committed.
.env.local
.env.*.local

# Editor / IDE
.idea/
*.iml
*.swp
*.swo

# Claude Code local settings + transient worktrees
.claude/settings.local.json
.claude/worktrees/

# OS noise
.DS_Store
Thumbs.db

# Docs site (Astro / Starlight)
docs/node_modules/
docs/dist/
docs/.astro/
