    "/audio/events": {
      "get": {
        "operationId": "events",
        "tags": [
          "Audio"
        ],
        "summary": "Stream transcode progress as Server-Sent Events",
        "description": "Opens a `text/event-stream` that polls the derived object and emits a `transcode` event (`{state: pending|ready}`) until it is produced, then ends — a live progress feed the browser reads with `EventSource`. Requires a bearer JWT and the admin capability.",
        "parameters": [
          {
            "name": "file",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
