    "/audio/uploads/direct": {
      "post": {
        "operationId": "upload_direct",
        "tags": [
          "Audio"
        ],
        "summary": "Upload an audio file directly as multipart/form-data",
        "description": "The single-round-trip alternative to the presigned flow: the client posts a `multipart/form-data` body with a `file` part; the server buffers the part and stores it, then returns the object key plus a presigned GET URL. The part's filename is validated against the same anti-traversal allowlist as the presigned path. Requires a bearer JWT and the admin capability.",
