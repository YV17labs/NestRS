---
/** Full logo watermarks — remove with PageFrame override to drop. */
const ringPath = `M0,-180
  L28,-160 L65,-168 L92,-140 L130,-136
  L146,-100 L180,-82 L176,-42 L198,0
  L176,42 L180,82 L146,100 L130,136
  L92,140 L65,168 L28,160 L0,180
  L-28,160 L-65,168 L-92,140 L-130,136
  L-146,100 L-180,82 L-176,42 L-198,0
  L-176,-42 L-180,-82 L-146,-100 L-130,-136
  L-92,-140 L-65,-168 L-28,-160 Z`;

const markPath = `M0,-110
  C60,-80 88,-25 72,55
  L0,110
  L-72,55
  C-88,-25 -60,-80 0,-110Z`;

const cutPath = `M0,-55
  C25,-40 40,-10 34,30
  L0,58
  L-34,30
  C-40,-10 -25,-40 0,-55Z`;

const LOGO_COUNT = 20;

const logos = Array.from({ length: LOGO_COUNT }, (_, i) => {
  const n = i + 1;
  return { class: `logo--${n}`, grad: `logo-grad-${n}` } as const;
});
---

<div class="nestrs-brand-bg" aria-hidden="true">
  {
    logos.map(({ class: logoClass, grad }) => {
      const wrapClass = logoClass.replace('logo--', 'logo-wrap--');
      return (
        <div class:list={['logo-wrap', wrapClass]}>
          <svg
            class:list={['logo', logoClass]}
            viewBox="0 0 512 512"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <linearGradient id={grad} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#ff4d5f" />
                <stop offset="100%" stop-color="#ff7a59" />
              </linearGradient>
            </defs>
            <g transform="translate(256,256)">
              <path
                class="logo-ring"
                d={ringPath}
                stroke-width="1.5"
                stroke-linejoin="round"
              />
              <circle class="logo-disc" r="120" />
              <path class="logo-mark" d={markPath} fill={`url(#${grad})`} />
              <path class="logo-cut" d={cutPath} />
            </g>
          </svg>
        </div>
      );
    })
  }
</div>
