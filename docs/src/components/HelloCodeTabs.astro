---
import { Code } from 'astro-expressive-code/components';

interface Tab {
  id: string;
  label: string;
  file: string;
  code: string;
}

/** Most important first — HTTP surface → logic → wiring → boot. */
const tabs: Tab[] = [
  {
    id: 'controller',
    label: 'Controller',
    file: 'apps/hello/src/controller.rs',
    code: `use std::sync::Arc;
use nest_rs_http::{controller, routes};

use crate::service::HelloService;

#[controller(path = "/")]
pub struct HelloController {
    #[inject]
    svc: Arc<HelloService>,
}

#[routes]
impl HelloController {
    #[get("/")]
    async fn hello(&self) -> String {
        self.svc.greeting()
    }
}`,
  },
  {
    id: 'service',
    label: 'Service',
    file: 'apps/hello/src/service.rs',
    code: `use nest_rs_core::injectable;

#[injectable]
#[derive(Default)]
pub struct HelloService;

impl HelloService {
    pub fn greeting(&self) -> String {
        "Hello World".to_string()
    }
}`,
  },
  {
    id: 'module',
    label: 'Module',
    file: 'apps/hello/src/module.rs',
    code: `use nest_rs_core::module;
use nest_rs_http::HttpModule;
use nest_rs_opentelemetry::OpenTelemetryModule;

use crate::controller::HelloController;
use crate::service::HelloService;

#[module(
    imports = [
        OpenTelemetryModule,
        HttpModule::for_root(None),
    ],
    providers = [HelloService, HelloController],
)]
pub struct HelloModule;`,
  },
  {
    id: 'main',
    label: 'Main',
    file: 'apps/hello/src/main.rs',
    code: `use anyhow::Result;
use nest_rs_config::Environment;
use nest_rs_core::App;
use nest_rs_opentelemetry::OpenTelemetry;

use hello::HelloModule;

#[tokio::main]
async fn main() -> Result<()> {
    let _environment = Environment::init();
    let _telemetry = OpenTelemetry::init("hello")?;

    App::builder()
        .module::<HelloModule>()
        .build()
        .await?
        .run()
        .await
}`,
  },
];

const filesJson = JSON.stringify(Object.fromEntries(tabs.map((t) => [t.id, t.file])));
---

<div
  class="nestrs-code-tabs not-content"
  data-nestrs-code-tabs
  data-files={filesJson}
>
  <div class="nestrs-code-tabs__chrome">
    <div class="nestrs-code-tabs__dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="nestrs-code-tabs__tabs" role="tablist" aria-label="Hello app source">
      {
        tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            class:list={['nestrs-code-tabs__tab', { 'is-active': i === 0 }]}
            data-tab-id={tab.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            id={`hello-tab-${tab.id}`}
            aria-controls={`hello-panel-${tab.id}`}
          >
            {tab.label}
          </button>
        ))
      }
    </div>
    <div class="nestrs-code-tabs__path" data-tab-path>{tabs[0].file}</div>
    <span class="nestrs-code-tabs__label">Write</span>
  </div>
  <div class="nestrs-code-tabs__body">
    {
      tabs.map((tab, i) => (
        <div
          class="nestrs-code-tabs__panel"
          role="tabpanel"
          data-tab-panel={tab.id}
          id={`hello-panel-${tab.id}`}
          aria-labelledby={`hello-tab-${tab.id}`}
          hidden={i !== 0}
        >
          <Code code={tab.code} lang="rust" meta='frame="none"' />
        </div>
      ))
    }
  </div>
</div>

<script>
  function initCodeTabs(root: HTMLElement) {
    const files = JSON.parse(root.dataset.files ?? '{}') as Record<string, string>;
    const tabButtons = root.querySelectorAll<HTMLButtonElement>('[data-tab-id]');
    const panels = root.querySelectorAll<HTMLElement>('[data-tab-panel]');
    const pathEl = root.querySelector<HTMLElement>('[data-tab-path]');

    tabButtons.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tabId;
        if (!id) return;

        tabButtons.forEach((btn) => {
          const active = btn === tab;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-selected', active ? 'true' : 'false');
        });

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.tabPanel !== id;
        });

        if (pathEl && files[id]) {
          pathEl.textContent = files[id];
        }
      });
    });
  }

  document.querySelectorAll('[data-nestrs-code-tabs]').forEach((el) => {
    initCodeTabs(el as HTMLElement);
  });
</script>
